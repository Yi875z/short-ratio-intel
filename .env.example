# ============================================================
# short-ratio-intel 環境変数設定ファイル
# このファイルをコピーして .env を作成し、各値を入力してください
# .env は絶対にGitにコミットしないこと
# ============================================================

# --- J-Quants API ---
JQUANTS_EMAIL=your_email@example.com
JQUANTS_PASSWORD=your_password

# --- Gemini API ---
GEMINI_API_KEY=your_gemini_api_key
# 使用モデル（未設定時は gemini-3.5-flash）
GEMINI_MODEL=gemini-3.5-flash

# --- オプション: Slack通知 ---
SLACK_WEBHOOK_URL=

# --- オプション: ニュース検索API (Step 0用) ---
TAVILY_API_KEY=

# --- アプリ設定 ---
LOG_LEVEL=INFO
DATA_DIR=data
DB_PATH=data/short_ratio.db
REPORTS_DIR=data/reports
