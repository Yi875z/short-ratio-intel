# ============================================================
# Streamlit Community Cloud 用 Secrets テンプレート
# ------------------------------------------------------------
# Cloud では「Manage app → Settings → Secrets」にこの内容を貼り付ける。
# ローカルでは .streamlit/secrets.toml にコピーして使う（.gitignore 済み）。
#
# 注意:
#  - トップレベルのキー（下記）は Streamlit が os.environ にも反映するため、
#    config/settings.py の os.getenv() がそのまま読み取れる。
#  - TOML の仕様上、[auth] のような [セクション] より前に
#    トップレベルキーを書くこと（順序を入れ替えない）。
#  - 値の (ここに貼る) は丸ごと実際の値に置き換える。山括弧 < > は使わない。
# ============================================================

# --- Supabase(PostgreSQL) 接続文字列 ---
# Supabase ダッシュボード → Project Settings → Database → Connection string →
# 「Session pooler」の URI（postgresql://postgres.xxxx:[PASSWORD]@aws-...pooler.supabase.com:5432/postgres）
DATABASE_URL = "(ここにSupabaseのSession pooler接続文字列を貼る)"

# --- Gemini API ---
GEMINI_API_KEY = "(ここにGemini APIキーを貼る)"
GEMINI_MODEL = "gemini-3.5-flash"

# --- Tavily（市場テーマ・ニュース取得） ---
TAVILY_API_KEY = "(ここにTavily APIキーを貼る)"

# --- 任意: Slack 通知（不要なら空文字のまま） ---
SLACK_WEBHOOK_URL = ""

# ============================================================
# ログイン保護（このセクションがある時だけ bcrypt 認証が有効になる）
# password_hash は以下で生成して貼り付ける:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'好きなパスワード', bcrypt.gensalt()).decode())"
# 生成した $2b$... の文字列をそのまま password_hash に入れる。
# ============================================================
[auth]
username = "(ここにログインユーザー名を貼る)"
password_hash = "(ここに上記コマンドで生成したbcryptハッシュを貼る)"
